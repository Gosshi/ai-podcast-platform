{
  "name": "ai-podcast-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "ai:review": "bash scripts/ai-loop.sh review",
    "ai:fix": "bash scripts/ai-loop.sh fix",
    "ai:verify": "bash scripts/ai-loop.sh verify",
    "ai:issue-fix": "bash scripts/ai-loop.sh issue-fix",
    "seed:demo": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/seed-demo-data.mts",
    "lint": "eslint app src --ext .ts,.tsx",
    "test": "node --experimental-strip-types --experimental-specifier-resolution=node --test tests/**/*.test.mts",
    "quality:check": "node --experimental-strip-types scripts/scriptQualityCheck.mts",
    "test:stripe-fixtures": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/test-stripe-webhook-fixtures.mts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.3",
    "stripe": "^18.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "typescript": "^5.9.3"
  }
}
